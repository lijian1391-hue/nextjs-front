{
  "name": "medusa-next",
  "version": "1.0.3",
  "private": true,
  "author": "Kasper Fabricius Kristensen <kasper@medusajs.com> & Victor Gerbrands <victor@medusajs.com> (https://www.medusajs.com)",
  "description": "Next.js Starter to be used with Medusa V2",
  "keywords": [
    "medusa-storefront"
  ],
  "scripts": {
    "dev": "next dev --turbopack -p 8000",
    "build": "next build",
    "start": "next start -p 8000",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "preview": "node scripts/purge-cache.js && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "clear-cache": "node scripts/clear-cache.mjs",
    "deploy": "node scripts/purge-cache.js && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types cloudflare-env.d.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@medusajs/icons": "latest",
    "@medusajs/js-sdk": "latest",
    "@medusajs/ui": "latest",
    "@opennextjs/cloudflare": "^1.18.1",
    "dompurify": "^3.3.3",
    "lodash": "^4.17.21",
    "next": "15.3.9",
    "react": "19.0.4",
    "react-country-flag": "^3.1.0",
    "react-dom": "19.0.4",
    "server-only": "^0.0.1",
    "swiper": "^12.1.3",
    "webpack": "^5"
  },
  "devDependencies": {
    "@babel/core": "^7.17.5",
    "@medusajs/types": "latest",
    "@medusajs/ui-preset": "latest",
    "@types/dompurify": "^3.0.5",
    "@types/lodash": "^4.14.195",
    "@types/node": "17.0.21",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "^10.4.2",
    "eslint": "8.10.0",
    "eslint-config-next": "15.0.8",
    "postcss": "^8.4.8",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.0.23",
    "typescript": "^5.3.2",
    "wrangler": "^4.81.0"
  },
  "resolutions": {
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.4"
  },
  "overrides": {
    "react": "19.0.4",
    "react-dom": "19.0.4"
  },
  "packageManager": "yarn@4.12.0"
}
